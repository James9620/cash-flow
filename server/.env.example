NODE_ENV=development
PORT=3000

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=https://your-railway-app.up.railway.app/oauth-redirect
PLAID_WEBHOOK_URL=https://your-railway-app.up.railway.app/webhook

# Production auth. The iOS app exchanges Sign in with Apple for this app session.
AUTH_MODE=user-session
APPLE_BUNDLE_ID=com.jameslarkin.cashflow
SESSION_JWT_SECRET=
SESSION_JWT_ISSUER=cash-flow-server
SESSION_JWT_AUDIENCE=com.jameslarkin.cashflow
SESSION_JWT_EXPIRES_SECONDS=2592000

# Production token storage.
TOKEN_STORE_BACKEND=postgres
DATABASE_URL=
TOKEN_STORE_MIGRATE_JSON=true

# Production Plaid webhooks should be verified before the payload is trusted.
PLAID_WEBHOOK_VERIFICATION=true
PLAID_WEBHOOK_MAX_AGE_SECONDS=300
PLAID_WEBHOOK_KEY_CACHE_MS=3600000

# Local simulator fallback only. Never use this mode in production.
# AUTH_MODE=development-shared-secret
# API_SECRET_KEY=
